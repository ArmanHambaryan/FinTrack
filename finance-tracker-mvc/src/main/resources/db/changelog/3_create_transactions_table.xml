<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="3" author="artyom">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="transactions"/>
            </not>
        </preConditions>
        <createTable tableName="transactions">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="user_id" type="BIGINT">
                <constraints nullable="false"
                             referencedTableName="users"
                             referencedColumnNames="id"
                             foreignKeyName="fk_transactions_user"/>
            </column>

            <column name="amount" type="DECIMAL(15, 2)">
                <constraints nullable="false"/>
            </column>

            <column name="type" type="VARCHAR(10)">
                <constraints nullable="false"/>
            </column>

            <column name="transaction_date" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>

            <column name="description" type="TEXT"/>

            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="4" author="artyom">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="transaction_types"/>
            </not>
        </preConditions>
        <addLookupTable
                existingTableName="transactions" existingColumnName="type"
                newColumnDataType="VARCHAR(10)"
                newTableName="transaction_types" newColumnName="type_name"
                constraintName="fk_transaction_type"/>
    </changeSet>

    <changeSet id="5" author="artyom">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="transaction_types"/>
        </preConditions>
        <insert tableName="transaction_types">
            <column name="type_name" value="INCOME"/>
        </insert>
        <insert tableName="transaction_types">
            <column name="type_name" value="EXPENSE"/>
        </insert>
    </changeSet>

</databaseChangeLog>
